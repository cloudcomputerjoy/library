# Admin Dashboard Configuration

# Backend API URLs
REACT_APP_API_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000

# Environment
REACT_APP_ENV=development
REACT_APP_APP_NAME=Smart Library Admin

# OpenRouter AI Integration (Optional)
REACT_APP_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Books API (Optional - see guide below)
# Default: Uses free OpenLibrary API if not provided
REACT_APP_GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# Optional: Enable debug logging
REACT_APP_DEBUG=false
