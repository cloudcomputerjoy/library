# Smart Library Mobile App - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# SUPABASE AUTHENTICATION (NEW - Primary Auth)
# ============================================================================

# Supabase Project URL
EXPO_PUBLIC_SUPABASE_URL=https://wwlcmewowcwsbeebalxh.supabase.co

# Supabase Anon Key (public key - safe to expose in frontend)
# This is used for authentication and real-time subscriptions
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Ind3bGNtZXdvd2N3c2JlZWJhbHhoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUyODg2MDgsImV4cCI6MjA5MDg2NDYwOH0.TTMQs6QSe63HeBpKosFjp-F4RM1sWbL_exdOYNq0QY4

# Enable Supabase Auth
EXPO_PUBLIC_USE_SUPABASE_AUTH=true

# ============================================================================
# APP CONFIGURATION
# ============================================================================

# App name and version
EXPO_PUBLIC_APP_NAME=smart-library
EXPO_PUBLIC_APP_VERSION=1.0.0

# Environment (development, staging, production)
NODE_ENV=development

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API URL (for OTP, password reset, custom endpoints)
# For local dev: use your machine's IP address (not localhost) for mobile/emulator access
# Find your IP with: ipconfig (Windows) or ifconfig (Mac/Linux)
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# Socket.IO URL for real-time communication
EXPO_PUBLIC_SOCKET_URL=http://localhost:5000

# API request timeout (in milliseconds)
EXPO_PUBLIC_API_TIMEOUT=30000

# ============================================================================
# INSTITUTION EMAIL DOMAINS (Student Signup)
# ============================================================================
# Comma-separated list of allowed email domains for student registration
EXPO_PUBLIC_ALLOWED_DOMAINS=@aaub.edu.bd,@aiub.edu.bd

# ============================================================================
# FIREBASE CONFIGURATION (Push Notifications)
# ============================================================================

# Firebase API Key (from google-services.json or Firebase Console)
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY

# Firebase Auth Domain
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com

# Firebase Project ID
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID

# Firebase Storage Bucket
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app

# Firebase Messaging Sender ID
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID

# Firebase App ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID

# ============================================================================
# AUTHENTICATION
# ============================================================================

# JWT token expiry time (in seconds)
# Default: 24 hours
EXPO_PUBLIC_TOKEN_EXPIRY=86400

# Token refresh threshold (in milliseconds)
# Refresh token if less than 5 minutes remaining
EXPO_PUBLIC_TOKEN_REFRESH_THRESHOLD=300000

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable push notifications
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true

# Enable offline mode (AsyncStorage fallback)
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true

# Enable debug logging
EXPO_PUBLIC_DEBUG=false

# Enable dark mode support
EXPO_PUBLIC_ENABLE_DARK_MODE=true

# Enable biometric authentication (Face ID / Touch ID)
EXPO_PUBLIC_ENABLE_BIOMETRIC=true

# Enable deep linking
EXPO_PUBLIC_ENABLE_DEEP_LINKING=true

# ============================================================================
# QR CODE CONFIGURATION
# ============================================================================

# QR code refresh interval (in milliseconds)
# Default: 10 seconds
EXPO_PUBLIC_QR_REFRESH_INTERVAL=10000

# QR code expiry time (in milliseconds)
# Default: 15 seconds
EXPO_PUBLIC_QR_EXPIRY=15000

# ============================================================================
# FILE SHARING CONFIGURATION
# ============================================================================

# File auto-delete time (in milliseconds)
# Default: 30 minutes
EXPO_PUBLIC_FILE_AUTO_DELETE_TIME=1800000

# Maximum file upload size (in bytes)
# Default: 50MB
EXPO_PUBLIC_MAX_FILE_SIZE=52428800

# ============================================================================
# PRINT PORTAL CONFIGURATION
# ============================================================================

# Cost per page for black & white printing (in ₹)
EXPO_PUBLIC_PRINT_COST_BW=2

# Cost per page for color printing (in ₹)
EXPO_PUBLIC_PRINT_COST_COLOR=5

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Log level (debug, info, warn, error)
EXPO_PUBLIC_LOG_LEVEL=debug

# Enable detailed network request logging
EXPO_PUBLIC_ENABLE_NETWORK_LOGGING=true

# Enable AsyncStorage logging
EXPO_PUBLIC_ENABLE_STORAGE_LOGGING=true

# Enable debug panel in app
EXPO_PUBLIC_ENABLE_DEBUG_PANEL=true

# ============================================================================
# THIRD-PARTY SERVICES
# ============================================================================

# Google OAuth Client ID (for social login)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# GitHub OAuth Client ID (for social login)
EXPO_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here

# ============================================================================
# FIREBASE CLOUD MESSAGING (FCM) - PUSH NOTIFICATIONS
# ============================================================================

# Firebase API Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Messaging VAPID Key (for web push, optional for mobile)
EXPO_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here

# Sentry DSN (for error tracking)
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# ============================================================================
# DEEP LINKING
# ============================================================================

# Deep linking scheme
EXPO_PUBLIC_DEEP_LINK_SCHEME=smartlibrary

# Deep linking prefix
EXPO_PUBLIC_DEEP_LINK_PREFIX=smartlibrary://

# ============================================================================
# DEVELOPMENT ONLY (DO NOT USE IN PRODUCTION)
# ============================================================================

# Skip authentication (for dev testing)
SKIP_AUTH_VALIDATION=false

# Use mock data instead of real API
USE_MOCK_DATA=false

# Enable React DevTools
DEBUG_REACT=false
