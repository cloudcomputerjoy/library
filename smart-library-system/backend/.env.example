# ==============================================================================
# ENVIRONMENT CONFIGURATION - Smart Library Backend
# ==============================================================================
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=5000
API_HOST=http://localhost:5000

# ==============================================================================
# SUPABASE CONFIGURATION
# ==============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ==============================================================================
# FIREBASE CLOUD MESSAGING (FCM) - PUSH NOTIFICATIONS
# ==============================================================================
# Option 1: Using Firebase credentials file path
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# Option 2: Using environment variables (individual fields)
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_PRIVATE_KEY_ID=your-private-key-id
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_CLIENT_ID=123456789
# FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
# FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
# FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
# FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...

# Option 3: Using JSON string in environment variable
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=86400
QR_TOKEN_SECRET=your-qr-token-secret-key
QR_TOKEN_EXPIRY=15
SESSION_SECRET=your-session-secret-here

# ==============================================================================
# CLOUDFLARE R2 STORAGE
# ==============================================================================
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_BUCKET_NAME=library-files
CLOUDFLARE_BUCKET_URL=https://your-bucket.r2.cloudflairstorage.com

# ==============================================================================
# CORS & ALLOWED ORIGINS
# ==============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8081

# ==============================================================================
# DATABASE SETTINGS
# ==============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/smart_library
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# ==============================================================================
# REDIS CONFIGURATION (For Bull Job Queue)
# ==============================================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==============================================================================
# PAYMENT GATEWAY (SSLCommerz)
# ==============================================================================
SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASSWORD=your-store-password
SSLCOMMERZ_API_URL=https://sandbox.sslcommerz.com

# ==============================================================================
# EMAIL & SMS NOTIFICATIONS
# ==============================================================================
# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@smartlibrary.com
SMTP_FROM_NAME=Smart Library

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ==============================================================================
# RFID READER SETTINGS
# ==============================================================================
RFID_SERIAL_PORT=/dev/ttyUSB0
RFID_BAUD_RATE=9600
RFID_ENABLED=true

# ==============================================================================
# FILE SHARING & PRINT SYSTEM
# ==============================================================================
FILE_UPLOAD_MAX_SIZE=104857600
FILE_SHARE_EXPIRY_MINUTES=30
PRINT_QUEUE_CHECK_INTERVAL=5000
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,application/msword

# ==============================================================================
# LOGGING & MONITORING
# ==============================================================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
ENABLE_REQUEST_LOGGING=true

# ==============================================================================
# API RATE LIMITING
# ==============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================================================
# SOCKET.IO CONFIGURATION
# ==============================================================================
SOCKET_IO_CORS=true
SOCKET_IO_TRANSPORTS=websocket,polling

# ==============================================================================
# ADMIN CREDENTIALS (For Initial Setup)
# ==============================================================================
ADMIN_EMAIL=admin@smartlibrary.com
ADMIN_PASSWORD=ChangeMe@123
ADMIN_PHONE=+880012345678

# ==============================================================================
# FEATURES FLAGS
# ==============================================================================
ENABLE_RFID=true
ENABLE_FILE_SHARING=true
ENABLE_PRINT_SYSTEM=true
ENABLE_PAYMENTS=true
ENABLE_NOTIFICATIONS=true

# ==============================================================================
# ADVANCED SETTINGS
# ==============================================================================
API_KEY_LENGTH=32
FINE_PER_DAY=10
MAX_BOOKS_PER_STUDENT=5
BOOK_ISSUE_DAYS=14
GOOGLE_BOOKS_API_KEY=AIzaSyDq2EWAVI3IkbvL_eCJP9jLved-oueyI78
